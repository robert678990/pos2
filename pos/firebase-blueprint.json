{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Store items like grains, spices, etc.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name in Arabic" },
        "category": { "type": "string", "enum": ["حبوب", "قطاني", "عطارية", "مكسرات"] },
        "priceRetail": { "type": "number", "description": "Price per unit (Retail)" },
        "priceWholesale": { "type": "number", "description": "Price per unit (Wholesale)" },
        "unit": { "type": "string", "enum": ["kg", "g", "piece"] },
        "stock": { "type": "number" },
        "minStock": { "type": "number" },
        "costPrice": { "type": "number", "description": "Purchase price for profit calculation" },
        "barcode": { "type": "string" },
        "description": { "type": "string" },
        "tax": { "type": "number" },
        "imageUrl": { "type": "string" }
      },
      "required": ["name", "category", "priceRetail", "priceWholesale", "unit", "stock", "minStock", "costPrice"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Client information and credit tracking",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "balance": { "type": "number", "description": "Outstanding credit balance" },
        "creditLimit": { "type": "number" }
      },
      "required": ["name", "balance"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Transaction record",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "customerId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" },
              "type": { "type": "string", "enum": ["retail", "wholesale"] },
              "profit": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "paymentType": { "type": "string", "enum": ["cash", "credit"] },
        "profit": { "type": "number" },
        "dueDate": { "type": "string", "format": "date-time", "description": "Payment due date for credit sales" }
      },
      "required": ["timestamp", "items", "total", "paymentType"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Payment or credit history",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "customerId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["payment", "credit"] },
        "note": { "type": "string" }
      },
      "required": ["timestamp", "customerId", "amount", "type"]
    },
    "BoxSession": {
      "title": "BoxSession",
      "description": "A session of the cashbox",
      "type": "object",
      "properties": {
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "startBalance": { "type": "number" },
        "endBalance": { "type": "number" },
        "totalSales": { "type": "number" },
        "totalExpenses": { "type": "number" },
        "totalManualIn": { "type": "number" },
        "totalManualOut": { "type": "number" },
        "totalSupplierPayments": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "note": { "type": "string" },
        "autoAddSales": { "type": "boolean" },
        "autoAddCustomerPayments": { "type": "boolean" },
        "autoDeductPurchases": { "type": "boolean" },
        "autoDeductExpenses": { "type": "boolean" }
      },
      "required": ["startTime", "startBalance", "status"]
    },
    "BoxTransaction": {
      "title": "BoxTransaction",
      "description": "Manual entry in the cashbox",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["in", "out"] },
        "date": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["sessionId", "amount", "type", "date"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Vendor information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "balance": { "type": "number" },
        "category": { "type": "string" }
      },
      "required": ["name", "balance"]
    },
    "Purchase": {
      "title": "Purchase",
      "description": "Purchase record from supplier",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" },
              "total": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "paymentType": { "type": "string", "enum": ["cash", "credit"] }
      },
      "required": ["timestamp", "supplierId", "items", "total", "paymentType"]
    }
  },
  "firestore": {
    "/products/{productId}": { "schema": "Product", "description": "Inventory items" },
    "/customers/{customerId}": { "schema": "Customer", "description": "Client database" },
    "/suppliers/{supplierId}": { "schema": "Supplier", "description": "Vendor database" },
    "/sales/{saleId}": { "schema": "Sale", "description": "Sales records" },
    "/purchases/{purchaseId}": { "schema": "Purchase", "description": "Purchase records" },
    "/transactions/{transactionId}": { "schema": "Transaction", "description": "Credit/Payment history" },
    "/box_sessions/{sessionId}": { "schema": "BoxSession", "description": "Cashbox sessions" },
    "/box_transactions/{transactionId}": { "schema": "BoxTransaction", "description": "Manual cashbox entries" },
    "/logs/{logId}": { "schema": "Log", "description": "System operation logs" }
  }
}
