rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Fields: name (string), category (enum), priceRetail (number), priceWholesale (number), unit (enum), stock (number), minStock (number), costPrice (number)
    //
    // Collection: customers
    // Fields: name (string), phone (string), balance (number), creditLimit (number)
    //
    // Collection: suppliers
    // Fields: name (string), phone (string), balance (number), category (string)
    //
    // Collection: sales
    // Fields: timestamp (string), customerId (string), items (list), total (number), paymentType (enum), profit (number)
    //
    // Collection: purchases
    // Fields: timestamp (string), supplierId (string), items (list), total (number), paymentType (enum)
    //
    // Collection: transactions (Customer Transactions)
    // Fields: timestamp (string), customerId (string), amount (number), type (enum), note (string)
    //
    // Collection: supplier_transactions
    // Fields: timestamp (string), supplierId (string), amount (number), type (enum), note (string)
    //
    // Collection: expenses
    // Fields: date (string), description (string), amount (number), category (string), paymentType (enum)
    //
    // Collection: box_sessions
    // Fields: startTime (string), status (enum), startBalance (number)
    //
    // Collection: box_transactions
    // Fields: sessionId (string), amount (number), type (enum), date (string)
    //
    // Collection: users
    // Fields: email (string), role (string), uid (string)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          (request.auth.token.email != null && request.auth.token.email.lower() == "m.yassinelouahabi@gmail.com") ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    function isValidProduct(data) {
      return hasRequiredFields(['name', 'category', 'priceRetail', 'priceWholesale', 'unit', 'stock', 'minStock', 'costPrice']) &&
        data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
        data.category is string && data.category.size() > 0 &&
        data.priceRetail is number && data.priceRetail >= 0 &&
        data.priceWholesale is number && data.priceWholesale >= 0 &&
        data.unit is string && data.unit.size() > 0 &&
        data.stock is number &&
        data.minStock is number &&
        data.costPrice is number && data.costPrice >= 0 &&
        (!('barcode' in data) || data.barcode is string) &&
        (!('description' in data) || data.description is string) &&
        (!('price3' in data) || data.price3 is number) &&
        (!('unitCapacity' in data) || data.unitCapacity is number) &&
        (!('higherUnit' in data) || data.higherUnit is string) &&
        (!('displayColor' in data) || data.displayColor is string) &&
        (!('expiryDate' in data) || data.expiryDate is string) &&
        (!('tax' in data) || data.tax is number) &&
        (!('imageUrl' in data) || data.imageUrl is string);
    }

    function isValidCustomer(data) {
      return hasRequiredFields(['name', 'phone', 'balance', 'creditLimit']) &&
        data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
        data.phone is string &&
        data.balance is number &&
        data.creditLimit is number &&
        (!('customerNumber' in data) || data.customerNumber is string) &&
        (!('barcode' in data) || data.barcode is string) &&
        (!('address' in data) || data.address is string) &&
        (!('taxNumber' in data) || data.taxNumber is string) &&
        (!('commercialRegister' in data) || data.commercialRegister is string) &&
        (!('city' in data) || data.city is string) &&
        (!('streetName' in data) || data.streetName is string) &&
        (!('buildingNumber' in data) || data.buildingNumber is string) &&
        (!('postalCode' in data) || data.postalCode is string) &&
        (!('cardType' in data) || data.cardType is string) &&
        (!('cardNumber' in data) || data.cardNumber is string) &&
        (!('notes' in data) || data.notes is string) &&
        (!('sellingPriceType' in data) || data.sellingPriceType in ['retail', 'wholesale', 'price3']) &&
        (!('maxCreditInvoices' in data) || data.maxCreditInvoices is number) &&
        (!('creditPeriodDays' in data) || data.creditPeriodDays is number) &&
        (!('alertOnDelay' in data) || data.alertOnDelay is bool);
    }

    function isValidSupplier(data) {
      return hasRequiredFields(['name', 'balance']) &&
        data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
        data.balance is number &&
        (!('phone' in data) || data.phone is string) &&
        (!('category' in data) || data.category is string);
    }

    function isValidSale(data) {
      return hasRequiredFields(['timestamp', 'items', 'total', 'paymentType']) &&
        data.items is list && data.items.size() > 0 && data.items.size() < 100 &&
        data.total is number && data.total >= 0 &&
        data.paymentType in ['cash', 'credit'] &&
        (!('invoiceNumber' in data) || data.invoiceNumber is number) &&
        (!('customerId' in data) || data.customerId == null || data.customerId is string) &&
        (!('customerName' in data) || data.customerName is string) &&
        (!('subtotal' in data) || data.subtotal is number) &&
        (!('tax' in data) || data.tax is number) &&
        (!('discount' in data) || data.discount is number) &&
        (!('discountValue' in data) || data.discountValue is number) &&
        (!('discountRaw' in data) || data.discountRaw is number) &&
        (!('discountType' in data) || data.discountType in ['amount', 'percentage']) &&
        (!('paid' in data) || data.paid is number) &&
        (!('change' in data) || data.change is number) &&
        (!('profit' in data) || data.profit is number) &&
        (!('note' in data) || data.note is string) &&
        (!('dueDate' in data) || data.dueDate == null || data.dueDate is timestamp);
    }

    function isValidPurchase(data) {
      return hasRequiredFields(['timestamp', 'supplierId', 'items', 'total', 'paymentType']) &&
        data.items is list && data.items.size() > 0 && data.items.size() < 100 &&
        data.total is number && data.total >= 0 &&
        data.paymentType in ['cash', 'credit'] &&
        (!('invoiceNumber' in data) || data.invoiceNumber is number) &&
        (!('supplierName' in data) || data.supplierName is string) &&
        (!('paidAmount' in data) || data.paidAmount is number) &&
        (!('remainingAmount' in data) || data.remainingAmount is number) &&
        (!('note' in data) || data.note is string);
    }

    function isValidTransaction(data) {
      return hasRequiredFields(['timestamp', 'customerId', 'amount', 'type']) &&
        data.amount is number && data.amount >= 0 &&
        data.type in ['payment', 'credit'] &&
        (!('note' in data) || data.note is string);
    }

    function isValidSupplierTransaction(data) {
      return hasRequiredFields(['timestamp', 'supplierId', 'amount', 'type']) &&
        data.amount is number && data.amount >= 0 &&
        data.type in ['payment', 'credit'] &&
        (!('note' in data) || data.note is string);
    }

    function isValidExpense(data) {
      return hasRequiredFields(['date', 'description', 'amount', 'category', 'paymentType']) &&
        data.amount is number && data.amount >= 0 &&
        data.description is string &&
        data.category is string &&
        data.paymentType in ['cash', 'credit'];
    }

    function isValidBoxSession(data) {
      return hasRequiredFields(['startTime', 'startBalance', 'status']) &&
        data.startBalance is number &&
        data.status in ['open', 'closed'];
    }

    function isValidBoxTransaction(data) {
      return hasRequiredFields(['sessionId', 'amount', 'type', 'date']) &&
        data.amount is number &&
        data.type in ['in', 'out'] &&
        data.date is string;
    }

    function isValidUser(data) {
      return hasRequiredFields(['email', 'role']) &&
        data.email is string &&
        data.role in ['admin', 'staff', 'employee'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }

    // Products
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    // Customers
    match /customers/{customerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidCustomer(request.resource.data);
      allow update: if isAuthenticated() && isValidCustomer(request.resource.data);
      allow delete: if isAdmin();
    }

    // Suppliers
    match /suppliers/{supplierId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidSupplier(request.resource.data);
      allow update: if isAuthenticated() && isValidSupplier(request.resource.data);
      allow delete: if isAdmin();
    }

    // Sales
    match /sales/{saleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidSale(request.resource.data);
      allow update: if isAdmin() && isValidSale(request.resource.data);
      allow delete: if isAdmin();
    }

    // Purchases
    match /purchases/{purchaseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPurchase(request.resource.data);
      allow update: if isAdmin() && isValidPurchase(request.resource.data);
      allow delete: if isAdmin();
    }

    // Transactions (Customer)
    match /transactions/{transactionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data);
      allow update: if isAdmin() && isValidTransaction(request.resource.data);
      allow delete: if isAdmin();
    }

    // Supplier Transactions
    match /supplier_transactions/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidSupplierTransaction(request.resource.data);
      allow update: if isAdmin() && isValidSupplierTransaction(request.resource.data);
      allow delete: if isAdmin();
    }

    // Expenses
    match /expenses/{expenseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidExpense(request.resource.data);
      allow update: if isAdmin() && isValidExpense(request.resource.data);
      allow delete: if isAdmin();
    }

    // Box Sessions
    match /box_sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidBoxSession(request.resource.data);
      allow update: if isAuthenticated() && isValidBoxSession(request.resource.data);
      allow delete: if isAdmin();
    }

    // Box Transactions
    match /box_transactions/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidBoxTransaction(request.resource.data);
      allow update: if isAuthenticated() && isValidBoxTransaction(request.resource.data);
      allow delete: if isAdmin();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Logs
    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    // Users
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAdmin() && isValidUser(request.resource.data);
      allow update: if isAdmin() && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    // Test connection
    match /test/{docId} {
      allow read: if isAuthenticated();
    }
  }
}
